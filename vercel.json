{
  "version": 2,
  "buildCommand": "pnpm install && pnpm run build",
  "installCommand": "pnpm install",
  "env": {
    "NODE_ENV": "production"
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/artifacts/api-server/dist/vercel.mjs"
    },
    {
      "source": "/(.*)",
      "destination": "/artifacts/passos-verdes/dist/public/$1"
    }
  ],
  "functions": {
    "artifacts/api-server/dist/vercel.mjs": {
      "runtime": "nodejs20.x",
      "memory": 1024,
      "maxDuration": 60
    }
  }
}
