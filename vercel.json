{
  "version": 2,
  "buildCommand": "pnpm run build",
  "installCommand": "pnpm install",
  "env": {
    "NODE_ENV": "production"
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/vercel.js"
    },
    {
      "source": "/(.*)",
      "destination": "/artifacts/passos-verdes/dist/public/$1"
    }
  ],
  "functions": {
    "api/vercel.js": {
      "runtime": "vercel-node@latest",
      "memory": 1024,
      "maxDuration": 60
    }
  }
}
